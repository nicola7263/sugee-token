---
import { getTranslations } from '../i18n/utils';
const t = getTranslations('ja');
---

<section class="relative flex min-h-[100dvh] items-center overflow-hidden pt-20 pb-8">
  <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Main hero container -->
    <div class="relative overflow-hidden rounded-[2rem] border border-gold/15 bg-[#0d0d0d]">
      <div class="grid grid-cols-1 items-center lg:grid-cols-2">
        <!-- Text content (left) -->
        <div class="flex flex-col justify-center px-8 py-12 sm:px-12 md:px-16 lg:py-20 xl:py-24">
          <!-- Badge -->
          <div class="mb-6 inline-flex w-fit items-center gap-2 rounded-full border border-gold/30 bg-gold/10 px-4 py-1.5 opacity-0 animate-fade-in">
            <img src="/sugeetoken-icon.png" alt="" width="20" height="20" class="rounded-full" aria-hidden="true" />
            <span class="text-sm font-medium text-gold">$SUGEE TOKEN</span>
          </div>

          <h1
            class="font-display text-5xl font-black leading-[1.05] tracking-tighter text-text opacity-0 animate-fade-in-up md:text-6xl lg:text-7xl xl:text-8xl"
            data-i18n-html="hero.headline"
          >
            人間がやらかした。<br>だからAIが作った。
          </h1>

          <p
            class="mt-8 max-w-md text-lg text-text-muted opacity-0 animate-fade-in-up delay-200 md:text-xl"
            data-i18n="hero.sub"
          >
            {t.hero.sub}
          </p>

          <div class="mt-10 opacity-0 animate-fade-in-up delay-400">
            <a
              href="#how-to-buy"
              class="inline-flex items-center justify-center rounded-full border border-gold/70 bg-black/30 px-8 py-3 font-display text-base font-semibold tracking-wide text-gold transition-all hover:bg-gold hover:text-black hover:shadow-[0_0_24px_rgba(212,160,23,0.35)] active:scale-95"
              data-i18n="hero.cta"
            >
              {t.hero.cta}
            </a>
          </div>
        </div>

        <!-- Visual (right) -->
        <div class="relative flex items-end justify-center px-8 pb-8 lg:min-h-[500px] lg:px-0 lg:pb-0">
          <div class="absolute bottom-24 h-52 w-52 rounded-full bg-gold/15 blur-[80px]" aria-hidden="true"></div>
          <!-- hand-up as main character image -->
          <img
            src="/hand-up.webp"
            alt="$SUGEE"
            class="relative z-10 w-[270px] drop-shadow-[0_0_70px_rgba(212,160,23,0.2)] sm:w-[320px] md:w-[380px] lg:w-[450px]"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2">
    <div class="flex flex-col items-center gap-2 animate-pulse-subtle">
      <div class="h-8 w-px bg-gold/30"></div>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-gold/40">
        <path d="M12 5v14M5 12l7 7 7-7" />
      </svg>
    </div>
  </div>
</section>
