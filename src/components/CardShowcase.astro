---
---

<section class="relative overflow-hidden">
  <!-- Tiled sugee-card background -->
  <div
    class="absolute inset-0 opacity-20"
    style="background-image: url('/sugee-card.webp'); background-size: 200px auto; background-repeat: repeat;"
    aria-hidden="true"
  ></div>

  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-black/40" aria-hidden="true"></div>

  <!-- Layered content: character on top, logo overlapping from bottom -->
  <div class="relative z-10 flex items-end justify-center min-h-[680px] sm:min-h-[720px] md:min-h-[780px] lg:min-h-[860px]">
    <!-- Glow behind character -->
    <div class="absolute bottom-1/3 left-1/2 -translate-x-1/2 h-[360px] w-[360px] rounded-full bg-gold/10 blur-[100px] md:h-[480px] md:w-[480px]" aria-hidden="true"></div>

    <!-- sugeetoken-jp: in front, large, at bottom -->
    <img
      src="/sugeetoken-jp.webp"
      alt="すげぇトークン"
      class="absolute bottom-0 left-1/2 -translate-x-1/2 z-20 w-[95%] max-w-[640px] drop-shadow-[0_8px_40px_rgba(0,0,0,0.95)] sm:w-[85%] md:w-[78%]"
    />

    <!-- Character: behind logo text -->
    <img
      src="/hand-up.webp"
      alt="$SUGEE"
      class="relative z-10 w-[82%] max-w-[460px] drop-shadow-[0_0_80px_rgba(212,160,23,0.3)] sm:w-[68%] md:w-[52%]"
    />
  </div>
  </div>
</section>
