---
---

<section class="relative overflow-hidden">
  <!-- Tiled sugee-card background -->
  <div
    class="absolute inset-0 opacity-20"
    style="background-image: url('/sugee-card.webp'); background-size: 200px auto; background-repeat: repeat;"
    aria-hidden="true"
  ></div>

  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-black/40" aria-hidden="true"></div>

  <!-- Center content -->
  <div class="relative z-10 flex flex-col items-center justify-center py-24 md:py-32 lg:py-40">
    <!-- Subtle glow -->
    <div class="absolute h-[400px] w-[400px] rounded-full bg-gold/8 blur-[120px] md:h-[500px] md:w-[500px]" aria-hidden="true"></div>

    <img
      src="/hand-up.webp"
      alt="$SUGEE"
      class="relative z-10 w-[280px] drop-shadow-[0_0_80px_rgba(212,160,23,0.25)] sm:w-[360px] md:w-[440px] lg:w-[520px]"
    />
    <h2 class="relative z-10 -mt-6 font-display text-7xl font-black tracking-tighter text-white drop-shadow-[0_4px_24px_rgba(0,0,0,0.6)] sm:-mt-8 sm:text-8xl md:-mt-10 md:text-9xl lg:text-[10rem]">
      <span class="text-gold">$</span>SUGEE
    </h2>
  </div>
</section>
