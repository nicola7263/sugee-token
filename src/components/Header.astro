---
import { getTranslations } from '../i18n/utils';
const t = getTranslations('ja');
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-40 transition-all duration-300"
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-2">
      <img
        src="/sugeetoken-icon.png"
        alt="$SUGEE"
        width="36"
        height="36"
        class="rounded-full"
      />
      <span class="font-display text-lg font-bold tracking-tight text-text">$SUGEE</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden items-center gap-8 md:flex">
      <a href="#about" class="text-sm text-text-muted transition-colors hover:text-primary" data-i18n="nav.about">{t.nav.about}</a>
      <a href="#token-info" class="text-sm text-text-muted transition-colors hover:text-primary" data-i18n="nav.tokenInfo">{t.nav.tokenInfo}</a>
      <a href="#how-to-buy" class="text-sm text-text-muted transition-colors hover:text-primary" data-i18n="nav.howToBuy">{t.nav.howToBuy}</a>
      <a href="#community" class="text-sm text-text-muted transition-colors hover:text-primary" data-i18n="nav.community">{t.nav.community}</a>

      <!-- Language Toggle -->
      <div class="flex items-center rounded-full border border-border bg-bg-elevated p-0.5">
        <button
          data-lang-toggle="ja"
          class="rounded-full px-2.5 py-1 text-xs font-medium transition-colors bg-gold text-black"
          aria-label="日本語に切替"
        >JA</button>
        <button
          data-lang-toggle="en"
          class="rounded-full px-2.5 py-1 text-xs font-medium transition-colors text-text-muted"
          aria-label="Switch to English"
        >EN</button>
      </div>
    </div>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-btn"
      class="flex flex-col items-center justify-center gap-1.5 md:hidden"
      aria-label="メニューを開く"
      aria-expanded="false"
    >
      <span class="hamburger-line block h-0.5 w-6 bg-text transition-transform duration-300"></span>
      <span class="hamburger-line block h-0.5 w-6 bg-text transition-opacity duration-300"></span>
      <span class="hamburger-line block h-0.5 w-6 bg-text transition-transform duration-300"></span>
    </button>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 top-0 z-50 flex translate-x-full flex-col bg-bg/95 backdrop-blur-xl transition-transform duration-300 md:hidden"
    aria-hidden="true"
  >
    <div class="flex items-center justify-between px-4 py-4 sm:px-6">
      <a href="#" class="flex items-center gap-2">
        <img src="/sugeetoken-icon.png" alt="$SUGEE" width="36" height="36" class="rounded-full" />
        <span class="font-display text-lg font-bold tracking-tight text-text">$SUGEE</span>
      </a>
      <button id="mobile-menu-close" class="p-2 text-text" aria-label="メニューを閉じる">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="flex flex-1 flex-col items-center justify-center gap-8">
      <a href="#about" class="mobile-nav-link text-2xl font-medium text-text transition-colors hover:text-primary" data-i18n="nav.about">{t.nav.about}</a>
      <a href="#token-info" class="mobile-nav-link text-2xl font-medium text-text transition-colors hover:text-primary" data-i18n="nav.tokenInfo">{t.nav.tokenInfo}</a>
      <a href="#how-to-buy" class="mobile-nav-link text-2xl font-medium text-text transition-colors hover:text-primary" data-i18n="nav.howToBuy">{t.nav.howToBuy}</a>
      <a href="#community" class="mobile-nav-link text-2xl font-medium text-text transition-colors hover:text-primary" data-i18n="nav.community">{t.nav.community}</a>

      <div class="flex items-center rounded-full border border-border bg-bg-elevated p-0.5">
        <button
          data-lang-toggle="ja"
          class="rounded-full px-4 py-2 text-sm font-medium transition-colors bg-gold text-black"
          aria-label="日本語に切替"
        >JA</button>
        <button
          data-lang-toggle="en"
          class="rounded-full px-4 py-2 text-sm font-medium transition-colors text-text-muted"
          aria-label="Switch to English"
        >EN</button>
      </div>
    </div>
  </div>
</header>

<script is:inline>
(function () {
  var header = document.getElementById('site-header');
  var menuBtn = document.getElementById('mobile-menu-btn');
  var menu = document.getElementById('mobile-menu');
  var closeBtn = document.getElementById('mobile-menu-close');
  var mobileLinks = menu ? menu.querySelectorAll('.mobile-nav-link') : [];

  // Scroll: add backdrop blur
  var lastScroll = 0;
  window.addEventListener('scroll', function () {
    var y = window.scrollY;
    if (y > 20) {
      header.classList.add('bg-bg/80', 'backdrop-blur-lg', 'border-b', 'border-border');
    } else {
      header.classList.remove('bg-bg/80', 'backdrop-blur-lg', 'border-b', 'border-border');
    }
    lastScroll = y;
  }, { passive: true });

  function openMenu() {
    menu.classList.remove('translate-x-full');
    menu.classList.add('translate-x-0');
    menu.setAttribute('aria-hidden', 'false');
    menuBtn.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu.classList.remove('translate-x-0');
    menu.classList.add('translate-x-full');
    menu.setAttribute('aria-hidden', 'true');
    menuBtn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  if (menuBtn) menuBtn.addEventListener('click', openMenu);
  if (closeBtn) closeBtn.addEventListener('click', closeMenu);
  mobileLinks.forEach(function (link) {
    link.addEventListener('click', closeMenu);
  });

  // Language toggle
  document.querySelectorAll('[data-lang-toggle]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var lang = this.getAttribute('data-lang-toggle');
      if (window.__sugee) {
        window.__sugee.applyLang(lang);
      }
    });
  });
})();
</script>
