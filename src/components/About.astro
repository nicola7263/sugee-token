---
import { getTranslations } from '../i18n/utils';
const t = getTranslations('ja');
---

<section id="about" class="relative py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <!-- Two-column: Card image left, Text right -->
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Left: sugee-card with gold frame -->
      <div class="scroll-animate flex justify-center">
        <div class="relative inline-block">
          <div class="rounded-2xl border-2 border-gold/40 p-3 shadow-[0_0_60px_rgba(212,160,23,0.08)]">
            <img
              src="/sugee-card.webp"
              alt="$SUGEE Card"
              class="w-[300px] rounded-xl sm:w-[360px] md:w-[400px]"
            />
          </div>
          <!-- Corner ornaments -->
          <div class="absolute -left-2 -top-2 h-6 w-6 border-l-2 border-t-2 border-gold"></div>
          <div class="absolute -right-2 -top-2 h-6 w-6 border-r-2 border-t-2 border-gold"></div>
          <div class="absolute -bottom-2 -left-2 h-6 w-6 border-b-2 border-l-2 border-gold"></div>
          <div class="absolute -bottom-2 -right-2 h-6 w-6 border-b-2 border-r-2 border-gold"></div>
        </div>
      </div>

      <!-- Right: Text content -->
      <div>
        <div class="scroll-animate mb-4 h-px w-12 bg-gold"></div>
        <h2
          class="scroll-animate font-display text-3xl font-bold tracking-tight text-text md:text-4xl lg:text-5xl"
          data-i18n="about.title"
        >
          {t.about.title}
        </h2>

        <div class="mt-8 space-y-5 text-lg leading-relaxed text-text-muted">
          <p class="scroll-animate" data-i18n="about.p1">{t.about.p1}</p>
          <p class="scroll-animate text-xl font-semibold text-gold" data-i18n="about.p2">{t.about.p2}</p>
          <p class="scroll-animate" data-i18n="about.p3">{t.about.p3}</p>
          <p class="scroll-animate" data-i18n="about.p4">{t.about.p4}</p>
        </div>
      </div>
    </div>

    <!-- Comparison Table -->
    <div class="scroll-animate mt-20">
      <!-- Desktop table -->
      <div class="hidden md:block overflow-hidden rounded-lg border border-border">
        <table class="w-full">
          <thead>
            <tr class="border-b border-border bg-bg-elevated">
              <th class="px-6 py-4 text-left text-sm font-semibold text-text-muted" data-i18n="about.tableHuman">{t.about.tableHuman}</th>
              <th class="px-6 py-4 text-left text-sm font-semibold text-gold" data-i18n="about.tableAI">{t.about.tableAI}</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <tr>
              <td class="px-6 py-4 text-text-muted" data-i18n="about.row1h">{t.about.row1h}</td>
              <td class="px-6 py-4 text-text" data-i18n="about.row1a">{t.about.row1a}</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-text-muted" data-i18n="about.row2h">{t.about.row2h}</td>
              <td class="px-6 py-4 text-text" data-i18n="about.row2a">{t.about.row2a}</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-text-muted" data-i18n="about.row3h">{t.about.row3h}</td>
              <td class="px-6 py-4 text-text" data-i18n="about.row3a">{t.about.row3a}</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-text-muted" data-i18n="about.row4h">{t.about.row4h}</td>
              <td class="px-6 py-4 font-semibold text-text" data-i18n="about.row4a">{t.about.row4a}</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Mobile cards -->
      <div class="space-y-4 md:hidden">
        {[
          { h: 'about.row1h', a: 'about.row1a', hv: t.about.row1h, av: t.about.row1a },
          { h: 'about.row2h', a: 'about.row2a', hv: t.about.row2h, av: t.about.row2a },
          { h: 'about.row3h', a: 'about.row3a', hv: t.about.row3h, av: t.about.row3a },
          { h: 'about.row4h', a: 'about.row4a', hv: t.about.row4h, av: t.about.row4a },
        ].map((row) => (
          <div class="rounded-lg border border-border bg-bg-elevated p-4">
            <div class="flex items-start gap-3">
              <div class="mt-1 h-2 w-2 shrink-0 rounded-full bg-text-muted"></div>
              <p class="text-sm text-text-muted" data-i18n={row.h}>{row.hv}</p>
            </div>
            <div class="mt-3 flex items-start gap-3">
              <div class="mt-1 h-2 w-2 shrink-0 rounded-full bg-gold"></div>
              <p class="text-sm font-medium text-text" data-i18n={row.a}>{row.av}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
