---
import { getTranslations } from '../i18n/utils';
const t = getTranslations('ja');

const CA = 'G1DbmrH8EvB9x3rjjuPP8tyAjk6ECbt97cJ83ubQpump';

const infoRows = [
  { labelKey: 'tokenInfo.name', valueKey: 'tokenInfo.nameValue', label: t.tokenInfo.name, value: t.tokenInfo.nameValue },
  { labelKey: 'tokenInfo.chain', valueKey: 'tokenInfo.chainValue', label: t.tokenInfo.chain, value: t.tokenInfo.chainValue },
  { labelKey: 'tokenInfo.supply', valueKey: 'tokenInfo.supplyValue', label: t.tokenInfo.supply, value: t.tokenInfo.supplyValue },
  { labelKey: 'tokenInfo.presale', valueKey: 'tokenInfo.presaleValue', label: t.tokenInfo.presale, value: t.tokenInfo.presaleValue },
  { labelKey: 'tokenInfo.teamAlloc', valueKey: 'tokenInfo.teamAllocValue', label: t.tokenInfo.teamAlloc, value: t.tokenInfo.teamAllocValue },
  { labelKey: 'tokenInfo.vcAlloc', valueKey: 'tokenInfo.vcAllocValue', label: t.tokenInfo.vcAlloc, value: t.tokenInfo.vcAllocValue },
  { labelKey: 'tokenInfo.launch', valueKey: 'tokenInfo.launchValue', label: t.tokenInfo.launch, value: t.tokenInfo.launchValue },
];
---

<section id="token-info" class="relative py-24 md:py-32 bg-bg-elevated/50">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="scroll-animate mb-4 h-px w-12 bg-gold"></div>
    <div class="scroll-animate flex items-center gap-4">
      <img
        src="/sugeetoken-icon.png"
        alt="$SUGEE"
        width="64"
        height="64"
        class="rounded-full"
      />
      <h2
        class="font-display text-3xl font-bold tracking-tight text-text md:text-4xl lg:text-5xl"
        data-i18n="tokenInfo.title"
      >
        {t.tokenInfo.title}
      </h2>
    </div>

    <!-- Info rows (divide-y, no cards) -->
    <div class="scroll-animate mt-12 divide-y divide-border">
      {infoRows.map((row) => (
        <div class="flex flex-col gap-1 py-4 sm:flex-row sm:items-center sm:justify-between">
          <span class="text-sm font-medium text-text-muted" data-i18n={row.labelKey}>{row.label}</span>
          <span class="text-base font-semibold text-text" data-i18n={row.valueKey}>{row.value}</span>
        </div>
      ))}
    </div>

    <!-- Contract Address -->
    <div class="scroll-animate mt-12">
      <p class="text-sm font-medium text-text-muted" data-i18n="tokenInfo.ca">{t.tokenInfo.ca}</p>
      <div class="mt-3">
        <button
          id="copy-ca-btn"
          type="button"
          class="group flex w-full items-center justify-between gap-4 rounded-full border border-border bg-bg px-5 py-4 text-left transition-colors hover:border-gold"
          data-ca={CA}
        >
          <span class="min-w-0 flex-1 break-all font-mono text-sm font-semibold text-text sm:text-base">
            {CA}
          </span>
          <span class="shrink-0 rounded-full border border-border p-2 text-text transition-colors group-hover:border-gold group-hover:text-gold">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
              <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
            </svg>
          </span>
        </button>
      </div>
      <div class="mt-3">
        <a
          href={`https://solscan.io/token/${CA}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-sm text-text-muted transition-colors hover:text-primary"
          data-i18n="tokenInfo.verifySolscan"
        >
          {t.tokenInfo.verifySolscan} ↗
        </a>
      </div>
    </div>
  </div>
</section>

<script is:inline>
(function () {
  var btn = document.getElementById('copy-ca-btn');
  if (!btn) return;
  var ca = btn.getAttribute('data-ca');

  btn.addEventListener('click', function () {
    if (!navigator.clipboard) return;
    navigator.clipboard.writeText(ca).then(function () {
      // Toast with prefix/suffix verification
      var prefix = ca.slice(0, 6);
      var suffix = ca.slice(-4);
      var lang = localStorage.getItem('sugee-lang') || 'ja';
      var dict = window.__sugee && window.__sugee.translations[lang];
      var toastPrefix = (dict && dict['tokenInfo.toastPrefix']) || 'Copied: ';
      var ellipsis = (dict && dict['tokenInfo.toastEllipsis']) || '...';

      var toastEl = document.getElementById('toast');
      if (toastEl) {
        toastEl.textContent = toastPrefix + prefix + ellipsis + suffix;
        toastEl.classList.add('show');
        setTimeout(function () {
          toastEl.classList.remove('show');
        }, 3000);
      }
    });
  });
})();
</script>
